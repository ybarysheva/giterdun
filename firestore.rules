/**
 * @fileoverview Firestore Security Rules for the to-do list application.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model, ensuring that each user can only access and modify their own data.
 *
 * Data Structure:
 * All data is nested under /users/{userId}, where {userId} corresponds to the Firebase Authentication UID.
 * Lists are stored under /users/{userId}/lists/{listId}, with {listId} being the date (YYYY-MM-DD) of the list.
 *
 * Key Security Decisions:
 * - Users can only access their own data.
 * - List operations are secured by path-based authorization, allowing users to list their own lists.
 *
 * Denormalization for Authorization:
 *  - The `userId` is present in the path for both `/users/{userId}` and `/users/{userId}/lists/{listId}`, removing the need to store it within the document, or read it from the document.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Enforces user-level access control for the `/users/{userId}` collection.
     * @path /users/{userId}
     * @allow (create) Authenticated user with UID 'user123' can create their own user document.
     * @deny (create) Authenticated user with UID 'user123' cannot create a user document with a different ID ('user456').
     * @allow (get) Authenticated user with UID 'user123' can get their own user document.
     * @deny (get) Authenticated user with UID 'user123' cannot get a user document with a different ID ('user456').
     * @allow (list) Authenticated user with UID 'user123' can list user documents.
     * @deny (list) Authenticated user with UID 'user123' cannot list user documents.
     * @allow (update) Authenticated user with UID 'user123' can update their own user document.
     * @deny (update) Authenticated user with UID 'user123' cannot update a user document with a different ID ('user456').
     * @allow (delete) Authenticated user with UID 'user123' can delete their own user document.
     * @deny (delete) Authenticated user with UID 'user123' cannot delete a user document with a different ID ('user456').
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Enforces user-level access control for the `/users/{userId}/lists/{listId}` collection.
     * @path /users/{userId}/lists/{listId}
     * @allow (create) Authenticated user with UID 'user123' can create a list under their own user document.
     * @deny (create) Authenticated user with UID 'user123' cannot create a list under a different user's document ('user456').
     * @allow (get) Authenticated user with UID 'user123' can get a list under their own user document.
     * @deny (get) Authenticated user with UID 'user123' cannot get a list under a different user's document ('user456').
     * @allow (list) Authenticated user with UID 'user123' can list lists under their own user document.
     * @deny (list) Authenticated user with UID 'user123' cannot list lists under a different user's document ('user456').
     * @allow (update) Authenticated user with UID 'user123' can update a list under their own user document.
     * @deny (update) Authenticated user with UID 'user123' cannot update a list under a different user's document ('user456').
     * @allow (delete) Authenticated user with UID 'user123' can delete a list under their own user document.
     * @deny (delete) Authenticated user with UID 'user123' cannot delete a list under a different user's document ('user456').
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId}/lists/{listId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    match /users/{userId}/projects/{projectId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    match /users/{userId}/shopping/{docId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null
        && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
    }
  }
}