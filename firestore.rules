/**
 * @fileoverview Firestore Security Rules for the to-do list application.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model.  Each user can only
 * access data nested under their own user ID.  Anonymous authentication is
 * used to ensure that all users have a unique identifier.
 *
 * Data Structure:
 * Data is organized hierarchically under `/users/{userId}`, with each user
 * having a collection of lists at `/users/{userId}/lists/{listId}`. The `listId`
 * is the date of the list (YYYY-MM-DD).
 *
 * Key Security Decisions:
 * - User listing is not permitted.
 * - Write access is restricted to the owner of the document.
 * - The rules do NOT validate the data schema beyond basic authorization checks.
 *
 * Denormalization for Authorization:
 *  - The `List` and `Task` entities both contain a `userId` field, which is denormalized data
 *    for authorization purposes. This allows us to verify ownership without
 *    performing additional reads.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Checks if the user is signed in.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the authenticated user's UID matches the provided userId.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Checks if the authenticated user owns the existing document.
     * It verifies that the document exists and that the user ID matches the document's owner ID.
     */
    function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
    }

    /************************ USERS COLLECTION ************************/

    /**
     * @description Secures the /users/{userId} collection.
     * @path /users/{userId}
     * @allow (create) User with UID 'user123' can create their user document.
     * @deny (create) User with UID 'user123' cannot create a user document with a different UID ('user456').
     * @allow (get) User with UID 'user123' can read their user document.
     * @deny (get) User with UID 'user123' cannot read another user's document.
     * @allow (update) User with UID 'user123' can update their user document.
     * @deny (update) User with UID 'user123' cannot update another user's document.
     * @allow (delete) User with UID 'user123' can delete their user document.
     * @deny (delete) User with UID 'user123' cannot delete another user's document.
     * @principle Enforces document ownership and prevents unauthorized modifications.
     */
    match /users/{userId} {
      // Self-Creation:  A user can create their own document.
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow get: if isOwner(userId);
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);
      allow list: if false;
    }


    /************************ LISTS SUBCOLLECTION ************************/

    /**
     * @description Secures the /users/{userId}/lists/{listId} collection.
     * @path /users/{userId}/lists/{listId}
     * @allow (create) User with UID 'user123' can create a list under their user ID.
     * @deny (create) User with UID 'user123' cannot create a list under a different user ID ('user456').
     * @allow (get) User with UID 'user123' can read a list under their user ID.
     * @deny (get) User with UID 'user123' cannot read a list under a different user ID ('user456').
     * @allow (update) User with UID 'user123' can update a list under their user ID.
     * @deny (update) User with UID 'user123' cannot update a list under a different user ID ('user456').
     * @allow (delete) User with UID 'user123' can delete a list under their user ID.
     * @deny (delete) User with UID 'user123' cannot delete a list under a different user ID ('user456').
     * @principle Enforces document ownership and prevents unauthorized modifications.
     */
    match /users/{userId}/lists/{listId} {
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow get: if isOwner(userId);
        allow update: if isExistingOwner(userId) && request.resource.data.userId == userId;
        allow delete: if isExistingOwner(userId);
        allow list: if isOwner(userId);
    }
  }
}