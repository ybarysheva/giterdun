/**
 * @fileoverview Firestore Security Rules for the to-do application.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model. Each user, identified by their Firebase Authentication UID,
 * has exclusive access to their own data tree under the `/users/{userId}` path.
 *
 * Data Structure:
 * All data is nested under /users/{userId}/lists/{listId}.
 * - /users/{userId}: Root collection for user profiles. The 'userId' corresponds to the Firebase Authentication UID.
 * - /users/{userId}/lists/{listId}: Collection of lists, each representing a day's tasks. 'listId' is the date (YYYY-MM-DD).
 *
 * Key Security Decisions:
 * - User data is isolated based on the Firebase Authentication UID.
 * - Anonymous authentication is required for all operations.
 * - Users can only read and write data within their own user path.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Secures the root user document, ensuring only the authenticated user can manage their own profile.
     * @path /users/{userId}
     * @allow (create) Authenticated user creates their own user document with matching userId.
     * @allow (get, list, update, delete) Authenticated user reads, updates, or deletes their own user document.
     * @deny (create) User attempts to create a user document with a mismatched userId.
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return isSignedIn() && request.auth.uid == userId;
      }

      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Secures the daily list documents, ensuring only the authenticated user can manage their own lists.
     * @path /users/{userId}/lists/{listId}
     * @allow (create) Authenticated user creates a list document under their user ID.
     * @allow (get, list, update, delete) Authenticated user reads, updates, or deletes list documents under their user ID.
     * @deny (create, update, delete) User attempts to modify lists under a different user ID.
     * @principle Enforces document ownership for all operations on lists.
     */
    match /users/{userId}/lists/{listId} {
        function isSignedIn() {
          return request.auth != null;
        }

        function isOwner(userId) {
          return isSignedIn() && request.auth.uid == userId;
        }

        function isExistingOwner(userId) {
          return isOwner(userId) && resource != null;
        }

        allow get: if isOwner(userId);
        allow list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);
    }
  }
}