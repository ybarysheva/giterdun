/**
 * @fileoverview Firestore Security Rules for a single-user to-do application.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model. Each user can only
 * access data under their own user ID. This is achieved through path-based
 * authorization using the `userId` parameter. Anonymous Authentication is used
 * which guarantees that a `uid` is always available.
 *
 * Data Structure:
 * All data is nested under `/users/{userId}`, ensuring data isolation.
 * - /users/{userId}: Root collection for user profiles.
 * - /users/{userId}/lists/{listId}: Stores daily lists of tasks. The `listId`
 *   corresponds to the date (YYYY-MM-DD).
 *
 * Key Security Decisions:
 * - User data is strictly scoped to the authenticated user.
 * - List operations are secured by path-based authorization.
 * - Data validation is relaxed to allow rapid prototyping, except for
 *   checks that are essential for authorization and relational integrity.
 *
 * Denormalization for Authorization:
 * The data model denormalizes the `userId` into the `List` document. This
 * simplifies authorization checks.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Enforces user-ownership for the /users/{userId} collection.
     * @path /users/{userId}
     * @allow (create) - Authenticated user creates their own user document.
     * @deny (create) - Unauthenticated user tries to create a user document.
     * @deny (create) - Authenticated user tries to create another user's document (userId mismatch).
     * @allow (get) - Authenticated user can read their own user document.
     * @deny (get) - Authenticated user tries to read another user's document.
     * @allow (list) - Listing users is not allowed.
     * @principle Enforces document ownership; only the authenticated user can create their own user document.
     */
    match /users/{userId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }

      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId);
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Enforces user-ownership for the /users/{userId}/lists/{listId} collection.
     * @path /users/{userId}/lists/{listId}
     * @allow (create) - Authenticated user creates a list document under their user ID.
     * @deny (create) - Authenticated user tries to create a list document under another user's ID.
     * @deny (create) - Unauthenticated user tries to create a list document.
     * @allow (get) - Authenticated user can read a list document under their user ID.
     * @deny (get) - Authenticated user tries to read a list document under another user's ID.
     * @allow (list) - Authenticated user can list list documents under their user ID.
     * @deny (update) - Authenticated user tries to update a list document under another user's ID.
     * @deny (delete) - Authenticated user tries to delete a list document under another user's ID.
     * @principle Enforces document ownership; only the authenticated user can manage list documents under their own user ID.
     */
    match /users/{userId}/lists/{listId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }

      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if false;
      allow delete: if false;
    }
  }
}