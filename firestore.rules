/**
 * @fileoverview Firestore Security Rules for the Task Management Application.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model. Each user has a dedicated
 * data tree under `/users/{userId}`, and only that user can access that data.
 *
 * Data Structure:
 * All data is nested under /users/{userId}, including lists and tasks. This
 * structure ensures data isolation and simplifies security rules. Lists are stored
 * with the date as the document ID (YYYY-MM-DD).
 *
 * Key Security Decisions:
 * - User listing is implicitly disallowed by the rules structure.
 * - Anonymous authentication is enabled, providing a `uid` for all users.
 * - All write operations are strictly owner-only.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Enforces ownership for User documents.
     * @path /users/{userId}
     * @allow (create) User d2UF5060BPO1dr7OIkvGM843k6u2 can create their own user document.
     * @deny (create) User d2UF5060BPO1dr7OIkvGM843k6u2 cannot create a user document with a different userId.
     * @principle Enforces document ownership for writes.
     */
    match /users/{userId} {
      // Helper function to check if the authenticated user is the owner of the document.
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }

      // Allows a user to create their own user document.
      allow create: if isOwner(userId) && request.resource.data.id == userId;

      // Allows a user to get their own user document.
      allow get: if isOwner(userId);

      // Listing users is not allowed.
      allow list: if false;

      // Allows a user to update their own user document if it exists.
      allow update: if isOwner(userId) && resource.data.id == userId && resource != null;

      // Allows a user to delete their own user document if it exists.
      allow delete: if isOwner(userId) && resource != null;
    }

    /**
     * @description Enforces ownership for List documents under a user's data tree.
     * @path /users/{userId}/lists/{listId}
     * @allow (create) User d2UF5060BPO1dr7OIkvGM843k6u2 can create a list with listId "2025-10-06".
     * @deny (create) User d2UF5060BPO1dr7OIkvGM843k6u2 cannot create a list with listId "2025-10-07".
     * @principle Enforces document ownership for writes within the user's data tree.
     */
    match /users/{userId}/lists/{listId} {
      // Helper function to check if the authenticated user is the owner of the document.
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }

      // Allows a user to create a list under their user ID if the userId on the list matches the path.
      allow create: if isOwner(userId) && request.resource.data.userId == userId;

      // Allows a user to get their own list document.
      allow get: if isOwner(userId);

      // Allows a user to list their own list documents.
      allow list: if isOwner(userId);

      // Allows a user to update their own list document if it exists.
      allow update: if isOwner(userId) && resource != null;

      // Allows a user to delete their own list document if it exists.
      allow delete: if isOwner(userId) && resource != null;
    }
  }
}