/**
 * @fileoverview Firestore Security Rules for the Task Management Application.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model where each user can only
 * access data associated with their unique Firebase Authentication UID.
 *
 * Data Structure:
 * All data is nested under /users/{userId}, ensuring clear ownership.
 *  - /users/{userId}: Root collection for user data.
 *  - /users/{userId}/lists/{listId}: Contains daily task lists, where {listId} is the date (YYYY-MM-DD).
 *
 * Key Security Decisions:
 * - Anonymous Authentication: The application leverages Firebase Anonymous Authentication,
 *   so all users have a UID, even without a traditional login.
 * - User Data Isolation: All data resides under a user's UID, providing inherent isolation.
 * - No User Listing: Listing all users is not permitted for privacy and security reasons.
 * - No External Collection Lookups: Rules avoid using `get()` or `exists()` to reference
 *   other collections for authorization, ensuring scalability and performance.
 *
 * Denormalization for Authorization:
 * The 'List' documents under /users/{userId}/lists/{listId} are denormalized to include the 'userId' to ensure data consistency.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description: Enforces read and write access to a user's root document only to the authenticated user.
     * @path: /users/{userId}
     * @allow: (create) - Authenticated user can create their own user document if the userId matches their auth UID.
     * @allow: (get, update, delete) - Authenticated user can read, update, or delete their own user document.
     * @deny: Any other user attempting to access this document.
     * @principle: Enforces document ownership based on the user's authentication UID.
     */
    match /users/{userId} {
      // Checks if the user is signed in
      function isSignedIn() {
        return request.auth != null;
      }

      // Checks if the user is the owner of the resource
      function isOwner(userId) {
        return request.auth.uid == userId;
      }
      allow get: if isSignedIn() && isOwner(userId);
      allow list: if false; // Listing all users is not permitted.
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && isOwner(userId) && resource != null;
      allow delete: if isSignedIn() && isOwner(userId) && resource != null;
    }

    /**
     * @description: Manages access to daily task lists for a specific user.
     * @path: /users/{userId}/lists/{listId}
     * @allow: (create) Authenticated user can create a list if userId matches their auth UID and listId is a valid date string.
     * @allow: (get, update, delete) Authenticated user can read, update, or delete their own list.
     * @deny: Any other user attempting to access this list.
     * @principle: Enforces user-specific data access based on path and authentication.
     */
    match /users/{userId}/lists/{listId} {
      // Checks if the user is signed in
      function isSignedIn() {
        return request.auth != null;
      }

      // Checks if the user is the owner of the resource
      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      allow get: if isSignedIn() && isOwner(userId);
      allow list: if isSignedIn() && isOwner(userId);
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && isOwner(userId) && resource != null;
      allow delete: if isSignedIn() && isOwner(userId) && resource != null;
    }
  }
}